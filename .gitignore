# Hugo build artifacts
/public/
/resources/_gen/
/.hugo_build.lock

# Migration artifacts
/migration/cache/
/migration/input/

# Generic backup / "keep the original" files
*.bak
*.original.*

# Python tooling for migration scripts
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Node tooling (linters via npx; no package.json today, but future-proof)
node_modules/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cloudflare Wrangler cache
.wrangler/

# Logs and tmp files
*.log
*.tmp

# Editor / IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*~

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Secrets
.env
.env.*
!.env.example
